{
    "name": "sibidharan/zealphp-symfony",
    "description": "Run Symfony applications on ZealPHP — long-lived workers, kernel boots once, OpenSwoole HTTP server. Drop-in via Symfony Runtime component.",
    "type": "library",
    "license": "MIT",
    "keywords": ["symfony", "zealphp", "openswoole", "swoole", "runtime", "long-running", "performance"],
    "authors": [
        {
            "name": "Sibidharan Nandhakumar",
            "email": "sibi@selfmade.ninja"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-openswoole": "*",
        "sibidharan/zealphp": "^0.2.27",
        "symfony/runtime": "^7.1",
        "symfony/http-kernel": "^7.1",
        "symfony/http-foundation": "^7.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ZealPHP\\Symfony\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true,
            "composer/package-versions-deprecated": true
        }
    }
}
